{
    "glm_config": {
        "description": "glm画图参数配置",
        "type": "object",
        "items": {
            "base_url": {
                "description": "画图服务器base_url",
                "type": "string",
                "hint": "请填写画图服务器base_url",
                "default": "https://api.net11.cn/v1",
                "obvious_hint": false
            },
            "api_key": {
                "description": "画图AI的API密钥",
                "type": "string",
                "hint": "请填写你的画图AI API密钥",
                "default": "",
                "obvious_hint": false
